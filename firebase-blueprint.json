{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "Student record including personal and academic details.",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "rollNo": { "type": "string" },
        "name": { "type": "string" },
        "fatherName": { "type": "string" },
        "grade": { "type": "string" },
        "dob": { "type": "string" },
        "gender": { "type": "string" },
        "contact": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Withdrawn", "Alumni"] },
        "admissionDate": { "type": "string" },
        "examResults": {
          "type": "object",
          "properties": {
            "math": { "type": "number" },
            "science": { "type": "number" },
            "english": { "type": "number" }
          }
        },
        "attendanceStatus": { "type": "string" },
        "attendanceTime": { "type": "string" },
        "checkedByParent": { "type": "boolean" }
      },
      "required": ["name", "fatherName", "grade", "status"]
    },
    "FeeRecord": {
      "title": "FeeRecord",
      "description": "Financial record for student fee payments.",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "student": { "type": "string" },
        "rollNo": { "type": "string" },
        "grade": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["Paid", "Unpaid"] },
        "method": { "type": "string" }
      },
      "required": ["student", "grade", "amount", "date", "status"]
    },
    "Teacher": {
      "title": "Teacher",
      "description": "Faculty member record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "subject": { "type": "string" },
        "qualification": { "type": "string" },
        "joiningDate": { "type": "string" },
        "salary": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "On Leave", "Resigned"] },
        "assignedClasses": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["name", "email", "subject", "status"]
    },
    "School": {
      "title": "School",
      "description": "School enrollment record.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "boardId": { "type": "string" },
        "address": { "type": "string" },
        "contact": { "type": "string" },
        "principalEmail": { "type": "string" },
        "principalName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "boardId", "principalEmail", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification for admin.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "data": { "type": "object" },
        "timestamp": { "type": "string" },
        "read": { "type": "boolean" }
      },
      "required": ["type", "title", "message", "timestamp", "read"]
    }
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Collection of all students in the school."
    },
    "/fees/{feeId}": {
      "schema": "FeeRecord",
      "description": "Collection of all fee payment records."
    },
    "/teachers/{teacherId}": {
      "schema": "Teacher",
      "description": "Collection of all teachers in the school."
    },
    "/schools/{schoolId}": {
      "schema": "School",
      "description": "Collection of school enrollments."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Collection of system notifications for the owner."
    }
  }
}
